# Copy to .env and adjust. dotenv-rails loads this in development/test.

# --- Database ---
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=root
DATABASE_NAME=deskflex_development
DATABASE_NAME_TEST=deskflex_test

# --- Auth ---
# Generate one with: bin/rails secret
JWT_SECRET_KEY=replace_me_with_a_long_random_string

# --- CORS ---
# Comma-separate multiple origins if needed.
FRONTEND_ORIGIN=http://localhost:5173

# --- Server ---
PORT=3001
